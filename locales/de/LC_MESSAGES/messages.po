msgstr "Kein Signal"

msgid "Weak signal"
msgstr "Schwaches Signal"

msgid "Medium signal"
msgstr "Ausreichendes Signal"

msgid "Strong signal"
msgstr "Starkes Signal"

msgid "Channel"
msgstr "Kanal"

msgid "Signal"
msgstr "Signal"

