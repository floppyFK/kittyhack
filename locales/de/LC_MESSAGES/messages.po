msgstr "Verbunden"

msgid "Not connected"
msgstr "Nicht verbunden"

msgid "Enforce connection to this WLAN"
msgstr "Verbindung zu diesem WLAN erzwingen"

msgid "Modify this WLAN"
msgstr "Dieses WLAN ändern"

msgid "Failed to scan for available WLANs"
msgstr "Fehler beim scannen nach verfügbaren WLANs"

msgid "Available WLANs"
msgstr "Verfügbare WLANs"

